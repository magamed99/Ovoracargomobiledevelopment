# ──────────────────────────────────────────────────────
# Ovora Cargo — Environment Variables Template
# Copy this file to .env.local for local development.
# Production values are managed by the cloud platform
# (Vercel / Netlify environment settings).
# ──────────────────────────────────────────────────────

# Supabase — public keys (safe to expose in browser)
# These values are already hardcoded in utils/supabase/info.tsx
# Override here only if you fork the project with a new Supabase project.
# VITE_SUPABASE_PROJECT_ID=mkbcjxnoeevtkzaqcpsh
# VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Yandex Maps API key is loaded at runtime via Supabase Edge Function.
# Store it as a Supabase secret: supabase secrets set YANDEX_MAPS_API_KEY=<key>
# No frontend env var needed.

# Sentry — error monitoring (см. IMPROVEMENTS.md, пункт 0.3).
# Без этой переменной Sentry просто не инициализируется (no-op).
# В продакшене задаётся в настройках окружения Vercel/Netlify.
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project>

# Cloudflare Turnstile — капча на регистрации/логине/OTP (см. docs/TURNSTILE_SETUP.md).
# Без этой переменной виджет просто не рендерится (no-op), как и Sentry выше.
# VITE_TURNSTILE_SITE_KEY=<your-turnstile-site-key>

# ── E2E Tests (Playwright) ──────────────────────────────────────
# SUPABASE_URL=https://mkbcjxnoeevtkzaqcpsh.supabase.co
# SUPABASE_ANON_KEY=<your-anon-key>

